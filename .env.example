# Copy to .env and fill in your values. .env is gitignored.

# Required for `belt agent` (tournament loop). Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional overrides — these defaults are what the demo was built against.
# OPENROUTER_MODEL=deepseek/deepseek-v4-pro
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_REASONING_EFFORT=high   # low | medium | high | xhigh

# Optional — where pool bars + the DuckDB run store live. Defaults to ./data/
# ASTEROID_BELT_DATA_DIR=data
